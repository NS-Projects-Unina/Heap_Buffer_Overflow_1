# é importante modificare anche snort.conf
# cerca la riga ipvar HOME_NET any 
# stostituire any con la subnet -> 192.168.161.0/24

# Rileva qualsiasi connessione al server
alert tcp any any -> any 4444 (msg:"Accesso al servizio vulnerabile"; sid:1000001; rev:1;)

# Rileva lunghezze grandi
alert tcp any any -> any 4444 (msg:"Heap Overflow attempt (length > 64)"; flow:to_server,established; content:"|01|"; offset:0; depth:1; byte_test:4,>,64,1,big; sid:1000002; rev:3;)

# Pattern (AAAAA)
alert tcp any any -> any 4444 (msg:"Payload sospetto (AAAA overflow)"; content:"AAAAAAAA"; sid:1000003; rev:1;)